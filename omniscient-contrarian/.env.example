# CMC_API_KEY: CoinMarketCap Pro key — used for the Fear & Greed regime signal and as a
#   reliability fallback for quotes. (Per-token x402 quotes are paid per call, no key needed.)
CMC_API_KEY=your_coinmarketcap_pro_api_key
CMC_BASE_URL=https://pro-api.coinmarketcap.com
# TWAK_PRIVATE_KEY: the agent's signing key. NEVER commit this file with a real key —
#   .env is gitignored for this reason. Only ever keep the real key in your local .env.
TWAK_PRIVATE_KEY=your_wallet_private_key
TWAK_WALLET_ADDRESS=0xYourWalletAddress
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# ── Execution quality (protects PnL) ──
# SLIPPAGE_PCT: tight slippage around the pool quote (MEV protection). Default 1.5.
# MAX_PRICE_IMPACT: skip a trade if the pool fills worse than this % vs the real CMC
#   price — this is what keeps the agent out of thin/illiquid pools. Default 2.
SLIPPAGE_PCT=1.5
MAX_PRICE_IMPACT=2
# MAX_PER_TRADE_USD / MAX_DAILY_CUMULATIVE_USD: hard notional caps (defaults 100 / 2000).
MAX_PER_TRADE_USD=100
MAX_DAILY_CUMULATIVE_USD=2000

# ── Strategy / trading config ──
# SCAN_INTERVAL_MS: time between epochs (default 3600000 = 1h).
# BUY_THRESHOLD / SELL_THRESHOLD: conviction score cutoffs (default 70 / 30).
# POSITION_SIZE_PCT: each new position = this % of the live USDT balance (scales with
#   capital). Set to 0 to use a fixed TRADE_SIZE_USD instead. Default 10.
# MIN_TRADE_USD: floor on position size so trades aren't dust (default 2).
# TRADE_SIZE_USD: fixed notional, used only when POSITION_SIZE_PCT=0 (default 3).
# MAX_TRADES_PER_EPOCH: how many new positions to open per epoch (default 3).
# TAKE_PROFIT_PCT / STOP_LOSS_PCT: exit a position when it's up/down this % (default 4 / 5).
# HEARTBEAT_UTC_HOUR: force the daily minimum trade if none has happened by this UTC hour
#   (guarantees the competition's >=1 trade/day). Default 1.
SCAN_INTERVAL_MS=3600000
BUY_THRESHOLD=70
SELL_THRESHOLD=30
POSITION_SIZE_PCT=10
MIN_TRADE_USD=2
TRADE_SIZE_USD=5
MAX_TRADES_PER_EPOCH=3
TAKE_PROFIT_PCT=4
STOP_LOSS_PCT=5
HEARTBEAT_UTC_HOUR=1

# ── Trust Wallet Agent Kit (TWAK) ──
# Set to true AFTER installing the CLI (npm i -g @trustwallet/cli) and adding your
# Access ID + HMAC Secret from portal.trustwallet.com (saved to ~/.twak). When true,
# the agent routes swaps and x402 data payments through TWAK; otherwise it falls back
# to direct self-custody EIP-3009 signing with ethers.
USE_TWAK=false
# TWAK_BIN=twak
# TWAK_PASSWORD=your_twak_keystore_password
X402_TOKEN_CONTRACT=0x0000000000000000000000000000000000000000
ERC_8183_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_REGISTRATION_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
